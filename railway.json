{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --prefix server && python3 -m pip install -r ai/requirements.txt"
  },
  "deploy": {
    "startCommand": "bash -lc \"python3 ai/app.py & npm --prefix server start\"",
    "healthcheckPath": "/health"
  }
}